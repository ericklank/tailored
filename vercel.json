{
  "crons": [
    {
      "path": "/api/crawl",
      "schedule": "0 2 * * 1"
    }
  ],
  "rewrites": [
    { "source": "/report/:id", "destination": "/index.html" }
  ],
  "functions": {
    "api/crawl.js": { "maxDuration": 300 },
    "api/search.js": { "maxDuration": 30 },
    "api/search-stories.js": { "maxDuration": 30 },
    "api/ingest.js": { "maxDuration": 300 },
    "api/ingest-stories.js": { "maxDuration": 300 },
    "api/analyze.js": { "maxDuration": 60 },
    "api/generate-pdf.js": { "maxDuration": 30 }
  }
}
